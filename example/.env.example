# fl_env example — development tier
# Copy to .env before running `fl_env build`:
#   cp .env.example .env
#   cp .env.staging.example .env.staging
#   cp .env.production.example .env.production
#   FL_ENV_MASTER_KEY=<64-hex> dart run ../tool/fl_env_cli/bin/fl_env.dart build

API_URL=https://dev.api.example.com
API_KEY=dev_key_xxxxxxxxxxxxxxxxxxxxxxxx
TIMEOUT=30
DEBUG=true
TAGS=flutter,dart,mobile
BACKEND_URL=https://dev-backend.example.com:8080
